@model IEnumerable<Product>

<h1>Product List</h1>

<a asp-action="Create" class="btn btn-primary">Create</a>
<br />
<br />

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>SKU</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Category</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.SKU</td>
                <td>@product.Price.ToString("C")</td>
                <td>@product.Stock</td>
                <td>@product.Category</td>
                <td>
                    <a asp-action="Details" asp-route-id="@product.Id" class="btn-sm btn-secondary">Details</a>
                    <span> </span>
                    <a asp-action="Edit" asp-route-id="@product.Id" class="btn-sm btn-secondary">Edit</a>
                    <span> </span>
                    <a asp-action="Delete" asp-route-id="@product.Id" class="btn-sm btn-secondary">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>